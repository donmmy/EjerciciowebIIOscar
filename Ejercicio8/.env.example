# Environment Variables - Blog API

# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
# For local development
DB_URI=mongodb://localhost:27017/blog

# For Railway/Production (use DATABASE_URL via Railway secrets)
# DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/blog

# JWT Configuration (MUST be at least 32 characters for security)
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long_here_!!!
JWT_EXPIRES_IN=7d

# Slack Webhook (Optional - for error notifications)
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
