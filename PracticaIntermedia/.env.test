# Test environment
PORT=3000
NODE_ENV=test

# MongoDB - Will be overridden by mongodb-memory-server
DB_URI=mongodb://localhost:27017/test

# JWT
JWT_SECRET=test_secret_key_12345678901234567890
JWT_LONG_EXPIRES_IN=2h
JWT_SHORT_EXPIRES_IN=15m

# Email (test configuration)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=test@gmail.com
EMAIL_PASSWORD=test_password
EMAIL_FROM=test@practica.com

# Slack (test configuration - disabled)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# Logging
LOG_LEVEL=error
LOG_DIR=./logs/test

# Others
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000
