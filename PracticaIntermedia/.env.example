# Configuración de la aplicación
PORT=3000
NODE_ENV=development

# Base de datos MongoDB
DB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/practicaintermedia?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=tu_clave_secreta_super_segura_123456789
JWT_LONG_EXPIRES_IN=2h
JWT_SHORT_EXPIRES_IN=15m

# Cloudinary (para subida de archivos)
CLOUDINARY_NAME=tu_cloudinary_name
CLOUDINARY_API_KEY=tu_cloudinary_api_key
CLOUDINARY_API_SECRET=tu_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=tu_upload_preset

# Cloudflare R2 (alternativa para subida de archivos)
R2_ACCOUNT_ID=tu_r2_account_id
R2_ACCESS_KEY_ID=tu_r2_access_key
R2_SECRET_ACCESS_KEY=tu_r2_secret_key
R2_BUCKET_NAME=mi-bucket

# Email (para recuperación de contraseña)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_contraseña_app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=debug